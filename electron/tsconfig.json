{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "../dist-electron",
    "rootDir": "..",
    "noEmit": false,
    "isolatedModules": false,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../types/electron-bridge.d.ts"
  ],
  "exclude": [
    "../node_modules"
  ]
}