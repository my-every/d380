    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/oxide": "4.2.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^37.2.3",
    "electron-builder": "^26.0.12",
    "playwright": "^1.59.1",
