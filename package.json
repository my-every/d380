    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.3"
  }
}
